{# Zapret2 config (DPI bypass via nfqws2-mikrotik)
   Шаблон — рендерится через ansible template: переменные берутся из _zapret2/vars.yml.
   Редактируй в UI Notes → "Конфиги": привяжи config.j2 к плейбуку zapret2, исправляй онлайн.
   При отсутствии Notes-привязки 03_config.yml использует этот файл как fallback. #}
NFQWS2_ENABLE=1
MODE_FILTER=all
INIT_APPLY_FW=1
DISABLE_IPV6=1
NFQWS2_PORTS_TCP=443
NFQWS2_TCP_PKT_OUT=20
NFQWS2_TCP_PKT_IN=10
NFQWS2_OPT="{{ nfqws2_strategy }}"
